@model libreria.Models.Prestamo
@{
    ViewData["Title"] = "Eliminar préstamo";
}

<div class="page-header">
    <div>
        <h1>Eliminar préstamo</h1>
        <p class="text-muted mb-0">Esta acción no se puede deshacer</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card border-danger">
            <div class="card-body p-4">
                <div class="alert alert-danger">
                    ⚠️ ¿Estás seguro de que deseas eliminar este préstamo?
                </div>
                <dl class="row">
                    <dt class="col-sm-5">ID</dt>
                    <dd class="col-sm-7">#@Model.Id</dd>
                    <dt class="col-sm-5">Usuario</dt>
                    <dd class="col-sm-7">@Model.Usuario?.Nombre</dd>
                    <dt class="col-sm-5">Libro</dt>
                    <dd class="col-sm-7">@Model.Libro?.Titulo</dd>
                    <dt class="col-sm-5">Fecha préstamo</dt>
                    <dd class="col-sm-7">@Model.FechaPrestamo.ToString("dd/MM/yyyy")</dd>
                    <dt class="col-sm-5">Estado</dt>
                    <dd class="col-sm-7">@(Model.Devuelto ? "Devuelto" : "Activo")</dd>
                </dl>
                <form asp-action="Delete" method="post" class="d-flex gap-2 mt-3">
                    <input name="id" value="@Model.Id" type="hidden" />
                    <button type="submit" class="btn btn-danger">Sí, eliminar</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </form>
            </div>
        </div>
    </div>
</div>
