@model IEnumerable<libreria.Models.Usuario>
@{
    ViewData["Title"] = "Usuarios";
}

<div class="page-header">
    <div>
        <h1>Usuarios</h1>
        <p class="text-muted mb-0">Gestión de usuarios registrados</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">+ Nuevo usuario</a>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Listado de usuarios</span>
        <span class="text-muted small">@Model.Count() registros</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted empty-state">
                <div style="font-size:3rem">👤</div>
                <p>No hay usuarios registrados aún.</p>
                <a asp-action="Create" class="btn btn-primary btn-sm">Agregar el primero</a>
            </div>
        }
        else
        {
            <div class="table-toolbar">
                <input class="form-control" type="search" data-table-search="#tablaUsuarios" placeholder="Buscar por nombre, correo o fecha" />
            </div>
            <div class="table-responsive">
            <table id="tablaUsuarios" class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Nombre</th>
                        <th>Email</th>
                        <th>Fecha registro</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var usuario in Model)
                    {
                        <tr>
                            <td class="text-muted">@usuario.Id</td>
                            <td class="fw-medium">@usuario.Nombre</td>
                            <td>@usuario.Email</td>
                            <td class="text-muted small">@usuario.FechaRegistro.ToString("dd/MM/yyyy")</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@usuario.Id" class="btn btn-outline-secondary btn-action me-1">Editar</a>
                                <a asp-action="Delete" asp-route-id="@usuario.Id" class="btn btn-outline-danger btn-action">Eliminar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        }
    </div>
</div>
