@model libreria.Models.Usuario
@{
    ViewData["Title"] = "Eliminar usuario";
}

<div class="page-header">
    <div>
        <h1>Eliminar usuario</h1>
        <p class="text-muted mb-0">Esta acción no se puede deshacer</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card border-danger">
            <div class="card-body p-4">
                <div class="alert alert-danger">
                    ⚠️ ¿Estás seguro de que deseas eliminar a <strong>@Model.Nombre</strong>?
                </div>
                <dl class="row">
                    <dt class="col-sm-4">ID</dt>
                    <dd class="col-sm-8">#@Model.Id</dd>
                    <dt class="col-sm-4">Nombre</dt>
                    <dd class="col-sm-8">@Model.Nombre</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>
                    <dt class="col-sm-4">Registro</dt>
                    <dd class="col-sm-8">@Model.FechaRegistro.ToString("dd/MM/yyyy")</dd>
                </dl>
                <form asp-action="Delete" method="post" class="d-flex gap-2 mt-3">
                    <input name="id" value="@Model.Id" type="hidden" />
                    <button type="submit" class="btn btn-danger">Sí, eliminar</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </form>
            </div>
        </div>
    </div>
</div>
